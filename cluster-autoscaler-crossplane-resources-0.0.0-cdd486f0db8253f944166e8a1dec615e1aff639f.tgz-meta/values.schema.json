{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "aws": {
            "type": "object",
            "properties": {
                "account": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string"
                        }
                    }
                },
                "enabled": {
                    "type": "boolean"
                },
                "oidc": {
                    "type": "object",
                    "properties": {
                        "domains": {
                            "type": "array"
                        }
                    }
                },
                "partition": {
                    "type": "string"
                }
            }
        },
        "clusterID": {
            "type": "string"
        },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                }
            }
        }
    }
}
